# Keep the build context small and secrets out of the image.
# NOTE: this file is shared by BOTH the AWS API Dockerfile and Hugging Face's
# Streamlit SDK build. Do NOT ignore `ui/` — HF's build copies the repo and
# needs `ui/streamlit_app.py` as its entry point. (The AWS image harmlessly
# includes the unused UI file.)
.venv/
.git/
.gitignore
.pytest_cache/
.ruff_cache/
.streamlit/
data/
tests/
n8n/
**/__pycache__/
*.pyc
.env
.env.*
!.env.example
CLAUDE.md
INTERVIEW_CHEATSHEET.md
*.md
Dockerfile
docker-compose.yml
