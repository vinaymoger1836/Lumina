# Copy this file to .env and fill in real values. NEVER commit .env.
# Groq — LLM (Llama 3.3 70B). Get a key at https://console.groq.com
GROQ_API_KEY=

# Qdrant Cloud — vector database. https://cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=

# Tavily — web search tool (needed in Phase 2). https://tavily.com
TAVILY_API_KEY=

# Hugging Face — deployment (needed for Phase 1 deploy). https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# ---- Optional tunables (sensible defaults applied in code) ----
# Qdrant collection name
QDRANT_COLLECTION=lumina_docs
# Embedding model (sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Groq chat model
GROQ_MODEL=llama-3.3-70b-versatile
