# Copy this file to .env and fill in real values. NEVER commit .env.
# Groq — LLM (Llama 3.3 70B). Get a key at https://console.groq.com
GROQ_API_KEY=

# Qdrant Cloud — vector database. https://cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=

# Tavily — web search tool (needed in Phase 2). https://tavily.com
TAVILY_API_KEY=

# Hugging Face — deployment (needed for Phase 1 deploy). https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# n8n webhooks (Phase 3) — shared secret the n8n workflows send in the
# X-Webhook-Token header to authenticate to /webhooks/*. Generate any long
# random string, e.g.  python -c "import secrets; print(secrets.token_urlsafe(32))"
# MUST be identical in the API's env and n8n's env.
N8N_WEBHOOK_TOKEN=

# ---- Phase 3: n8n / AWS EC2 deploy (see DEPLOY_AWS.md) ----
# Recipient of the daily digest email (n8n Gmail node).
DIGEST_RECIPIENT=
# Keep these as localhost so Google OAuth works over the SSH tunnel (no domain
# / HTTPS needed). Consumed by docker-compose.yml for the n8n container.
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Asia/Kolkata

# ---- Optional tunables (sensible defaults applied in code) ----
# Qdrant collection name
QDRANT_COLLECTION=lumina_docs
# Embedding model (sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Groq chat model
GROQ_MODEL=llama-3.3-70b-versatile
